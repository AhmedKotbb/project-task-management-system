# Server
PORT=3000
NODE_ENV=development

# PostgreSQL (must match docker-compose or your local DB)
DB_HOST=localhost
DB_USER=ptms
DB_PASSWORD=ptms_dev
DB_NAME=project_task_management

# JWT
JWT_ACCESS_SECRET=access-secret
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_SECRET=refresh-secret
JWT_REFRESH_EXPIRES_IN=7d

# Email (used when admins create new users to send them the initial password)
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-app-password

# Docker Compose overrides (optional — used by docker-compose.yml only)
POSTGRES_USER=ptms
POSTGRES_PASSWORD=ptms_dev
POSTGRES_DB=project_task_management
POSTGRES_PORT=5432
